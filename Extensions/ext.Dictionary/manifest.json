{
  "manifest_version": 3,
  "key": "",
  "name": "Thai Dictionary Assistant",
  "version": "1.0",
  "description": "Thai-English-Chinese dictionary assistant with on-page translation.",
  "permissions": [
    "system.display",
    "storage",
    "scripting",
    "sidePanel",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "https://translation.googleapis.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://*.firebaseio.com/*",
    "https://*.googleusercontent.com/*",
    "https://googleapi-w56agazoha-uc.a.run.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Thai Dictionary",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dialog.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "open-dictionary-dialog": {
      "suggested_key": {
        "default": "Alt+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open Thai Dictionary Dialog"
    }
  },
  "side_panel": {
    "default_path": "dialog.html"
  },
  "oauth2": {
    "client_id": "724993324937-b5qdbskdr8tpsp9u8s801n5nd8qffmg4.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile",
      "openid"
    ]
  }
}